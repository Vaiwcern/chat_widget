{
    "manifest_version": 3,
    "name": "AI Agent",
    "version": "1.0",
    "icons": {
        "16": "AIAgentLogoOnly.png",
        "32": "AIAgentLogoOnly.png",
        "48": "AIAgentLogoOnly.png",
        "128": "AIAgentLogoOnly.png"
    },
    "permissions": [
        "sidePanel",
        "storage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "action": {
        "default_title": ""
    },
    "background": {
        "service_worker": "background.js"
    },
    "side_panel": {
        "default_path": "panel.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "AIAgentLogoOnly.png",
                "AIAgentLogoOnly.png",
                "AIAgentLogoOnly.png",
                "AIAgentLogoOnly.png",
                "AIAgentLogoOnly.png",
                "aiavartandt.png",
                "logout.png"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'; frame-src 'self' blob: https: data:"
    }
}